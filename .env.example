# ─── Copy this file to .env.local and fill in your values ───

# MongoDB Atlas free cluster URI
# 1. Create free cluster at https://cloud.mongodb.com
# 2. Connect → Drivers → copy string → replace <password>
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.XXXXX.mongodb.net/campusbuzz?retryWrites=true&w=majority

# JWT secret for signing tokens
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string

# (Optional) Your deployed URL — used for CORS if needed
NEXT_PUBLIC_APP_URL=https://campusbuzz.vercel.app
